{
  "name": "simpsons-quote-terminal",
  "version": "1.0.0",
  "description": "Random quote generator connecting to a Simpsons quote API made to look like a Ubuntu terminal.",
  "main": "index.js",
  "scripts": {
    "sass": "sass scss/style.scss css/style.css --style=compressed",
    "sass:watch": "sass scss/style.scss css/style.css --style=compressed --watch",
    "serve": "browser-sync start --server --files \"css/*.css, js/*.js, *.html\"",
    "dev": "npm run sass:watch & npm run serve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaredcaraway/simpsons-quote-terminal.git"
  },
  "author": "Jared Caraway",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jaredcaraway/simpsons-quote-terminal/issues"
  },
  "homepage": "https://github.com/jaredcaraway/simpsons-quote-terminal#readme",
  "dependencies": {
    "browser-sync": "^3.0.4",
    "sass": "^1.98.0"
  }
}
